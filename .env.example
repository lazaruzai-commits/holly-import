# Holly Import — environment config
# Copy to .env and fill in real values. Never commit .env.

# OpenRouter (Kimi K2 / 2.6) for the chat agent.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=moonshotai/kimi-k2

# Telegram bot used for forwarding leads and chat transcripts.
# Bot: https://t.me/HollyImportBot
# To get TELEGRAM_CHAT_ID: send /start to the bot, then visit
#   https://api.telegram.org/bot<TOKEN>/getUpdates  and copy the "chat":{"id": ...}
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Public site base path (when reverse-proxied at andyluciani.com/holly).
# In production this is set by the systemd unit (Environment=APP_ROOT_PATH=/holly).
# For local dev leave the line below commented out so URLs resolve at /.
# APP_ROOT_PATH=/holly

# Public site name used in copy / page titles. Always full name in user-facing strings.
SITE_NAME=Holly Import
SITE_LOCATION=Los Palos Grandes, Caracas
SITE_PHONE=
SITE_WHATSAPP=
