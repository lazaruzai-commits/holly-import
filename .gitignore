.env
.venv/
__pycache__/
*.pyc
*.pyo
*.log

# Captured leads and chat transcripts — never commit
leads/*.csv
leads/*.jsonl

# Locally downloaded model imagery — large; fetched via scripts/fetch_images.py
static/img/models/*.jpg
static/img/models/*.jpeg
static/img/models/*.png
static/img/models/*.webp
!static/img/models/.gitkeep
# Exceptions: hand-processed cutouts that should NOT be auto-refreshed
!static/img/models/mg-rx9.jpg

# User-supplied raw photos waiting to be processed by scripts/process_local_images.py
# Originals never go to git — only the normalized output in static/img/models/
static/img/models/_source/*
!static/img/models/_source/.gitkeep

# OS / editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/
